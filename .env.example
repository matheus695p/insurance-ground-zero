# ============================================================================
# AI Chat Configuration
# ============================================================================

# --- Server-side only (set in Vercel dashboard, NOT prefixed with VITE_) ---
# These are used by the serverless API functions and never reach the browser.
ANTHROPIC_API_KEY=your-anthropic-api-key-here
OPENAI_API_KEY=your-openai-api-key-here

# --- Client-side (prefixed with VITE_, safe to expose) ---
# Choose your AI provider: "anthropic" or "openai"
VITE_AI_PROVIDER=anthropic

# Model selection (no secrets here, just model names)
VITE_ANTHROPIC_MODEL=claude-sonnet-4-20250514
VITE_OPENAI_MODEL=gpt-4o
